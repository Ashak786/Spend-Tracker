rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isValidUserProfile(data) {
      return data.keys().hasAll(['id', 'name', 'salary', 'joinedAt'])
        && isValidId(data.id)
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && (data.salary is int || data.salary is float) && data.salary >= 0
        && data.joinedAt is string && data.joinedAt.size() >= 10
        && (data.get('incentive', null) == null || ((data.incentive is int || data.incentive is float) && data.incentive >= 0))
        && (data.get('monthlyIncomes', null) == null || data.monthlyIncomes is map);
    }
    
    function isValidTransaction(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'amount', 'category', 'date'])
        && data.keys().size() >= 6 && data.keys().size() <= 8
        && isValidId(data.id)
        && isValidId(data.userId)
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && (data.amount is int || data.amount is float) && data.amount >= 0
        && data.category is string && data.category.size() > 0 && data.category.size() <= 100
        && data.date is string && data.date.size() == 10
        && (!('description' in data) || data.description == null || (data.description is string && data.description.size() <= 500))
        && (!('isRecurring' in data) || data.isRecurring == null || (data.isRecurring is bool));
    }
    
    // Users Collection
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isValidId(userId) && isValidUserProfile(request.resource.data);
      allow delete: if isValidId(userId);
    }
    
    // Transactions Collection
    match /transactions/{transactionId} {
      allow read: if true;
      allow create, update: if isValidId(transactionId) && isValidTransaction(request.resource.data);
      allow delete: if isValidId(transactionId);
    }
  }
}
